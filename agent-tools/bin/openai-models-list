#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/../.." && pwd)
ENV_FILE="$REPO_ROOT/.env"

PREFIX=""
JSON_OUTPUT=0

print_help() {
  cat <<'EOF'
openai-models-list

Fetch available model IDs from OpenAI Models API and print them.

Usage:
  openai-models-list [--prefix <value>] [--json]
  openai-models-list -h|--help

Options:
  --prefix <value>   Filter IDs by prefix (e.g. gpt-5)
  --json             Output full API response JSON
  -h, --help         Show this help

Environment:
  OPENAI_API_KEY     Required API key (falls back to repo root .env)
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help)
      print_help
      exit 0
      ;;
    --json)
      JSON_OUTPUT=1
      shift
      ;;
    --prefix)
      if [ "$#" -lt 2 ]; then
        echo "--prefix requires a value" >&2
        exit 1
      fi
      PREFIX="$2"
      shift 2
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

if [ -z "${OPENAI_API_KEY:-}" ] && [ -f "$ENV_FILE" ]; then
  OPENAI_API_KEY=$(
    sed -nE \
      "s/^[[:space:]]*(export[[:space:]]+)?OPENAI_API_KEY[[:space:]]*=[[:space:]]*['\"]?([^'\"#[:space:]]+)['\"]?[[:space:]]*(#.*)?$/\2/p" \
      "$ENV_FILE" \
      | head -n1
  )
  export OPENAI_API_KEY
fi

if [ -z "${OPENAI_API_KEY:-}" ]; then
  echo "OPENAI_API_KEY is required." >&2
  exit 1
fi

API_RESPONSE=$(
  curl -sS -w "\n%{http_code}" \
    -H "Authorization: Bearer $OPENAI_API_KEY" \
    "https://api.openai.com/v1/models"
)
HTTP_STATUS=$(printf '%s' "$API_RESPONSE" | tail -n1)
BODY=$(printf '%s' "$API_RESPONSE" | sed '$d')

if [ "$HTTP_STATUS" -lt 200 ] || [ "$HTTP_STATUS" -ge 300 ]; then
  echo "OpenAI Models API failed ($HTTP_STATUS): $BODY" >&2
  exit 1
fi

if [ "$JSON_OUTPUT" -eq 1 ]; then
  printf '%s\n' "$BODY"
  exit 0
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "jq is required for non-JSON output. Use --json or install jq." >&2
  exit 1
fi

if [ -n "$PREFIX" ]; then
  printf '%s' "$BODY" | jq -r --arg prefix "$PREFIX" '.data[]?.id | select(startswith($prefix))' | sort -u
else
  printf '%s' "$BODY" | jq -r '.data[]?.id' | sort -u
fi
