#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
AGENT_TOOLS_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
TOOL_DIR="$AGENT_TOOLS_DIR/git-diff-html"

if [ ! -d "$TOOL_DIR/node_modules" ]; then
  echo "Dependencies are not installed for git-diff-html." >&2
  echo "Run: (cd \"$TOOL_DIR\" && npm install)" >&2
  exit 1
fi

if [ ! -f "$TOOL_DIR/dist/index.js" ]; then
  echo "Build output is missing for git-diff-html." >&2
  echo "Run: (cd \"$TOOL_DIR\" && npm run build)" >&2
  exit 1
fi

exec node "$TOOL_DIR/dist/index.js" "$@"
