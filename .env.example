DISCORD_TOKEN=your_bot_token_here
AI_ADAPTER=claude  # claude (default) | codex
BATCH_ENABLED=false  # true で batch ジョブを有効化
DAILY_DIGEST_CHANNEL_ID=  # daily-digest を投稿するチャンネルID
DAILY_DIGEST_CRON=0 9 * * *  # 毎日 09:00（サーバーローカル時刻）
ANTHROPIC_MODELS_API_KEY=your_anthropic_api_key_here  # /models 用（ANTHROPIC_API_KEY は SDK が使用）
OPENAI_MODELS_API_KEY=your_openai_api_key_here  # /models 用（AI_ADAPTER=codex 時）
